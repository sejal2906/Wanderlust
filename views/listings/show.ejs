<% layout("layout/boilerplate") -%>

<style>
#map{
height:500px;
width:100%;
margin-top:20px;
}
</style>

<div class="container mt-4">

  <!-- Title -->
  <h2 class="mb-4 fw-bold text-center">
    <%= listing.title %>
  </h2>

  <!-- Image -->
  <div class="text-center mb-4">
    <img src="<%= listing.image.url %>" alt="Listing Image" class="img-fluid listing-img shadow">
  </div>
  <!-- Owner -->
  <p class="text-muted fs-5 text-center px-5">Owned by <%=listing.owner.username%></p>

  <!-- Description -->
  <p class="text-muted fs-5 text-center px-5">
    <%= listing.description %>
  </p>

  <!-- Price -->
  <h4 class="text-success text-center mb-3">
    &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
  </h4>

  <!-- Location -->
  <p class="text-center mb-1">
    <strong>Location:</strong> <%= listing.location %>
  </p>

  <!-- Country -->
  <p class="text-center mb-4">
    <strong>Country:</strong> <%= listing.country %>
  </p>

  <!-- Buttons -->
  <%if ((currUser) && (listing.owner._id.equals(currUser._id))){%>
  <div class="d-flex justify-content-center gap-3 mb-5">

    <form action="/listings/<%= listing._id %>/edit" method="get">
      <button class="btn btn-dark">
        Edit Listing
      </button>
    </form>

    <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
      <button class="btn btn-dark">
        Delete Listing
      </button>
    </form>

  </div>
  <%}%>

</div>
<hr>
<!-- ================= REVIEW FORM (NO CARD) ================= -->

<%if (currUser){%>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">

        <h3 class="text-center mb-4">✨ Give Your Review</h3>

        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

          <!-- Rating -->
          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="reviews[rating]" value="0" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="reviews[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="reviews[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="reviews[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="reviews[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="reviews[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>

          <!-- Comment -->
          <div class="mb-3">
            <label for="comment" class="form-label">Your Comment</label>
            <textarea class="form-control" id="comment" name="reviews[Comment]" rows="4" required placeholder="Write your thoughts here..."></textarea>
            <div class="invalid-feedback">
              Please provide feedback.
            </div>
          </div>

          <!-- Submit -->
          <div class="d-grid">
            <button type="submit" class="btn btn-dark">
              Submit Review
            </button>
          </div>

        </form>

      </div>
    </div>
  </div>
  <%}%>


<!-- ================= REVIEWS DISPLAY ================= -->

<div class="container mt-5">
  <h3 class="text-center mb-4">📝 Guest Reviews</h3>

  <% if(listing.reviews.length === 0){ %>
  <p class="text-center text-muted">
    No reviews yet. Be the first to review!
  </p>
  <% } %>

  <div class="row justify-content-center">

    <% for(let review of listing.reviews){ %>

    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-body">

          <h5 class="card-title">👤 <%=review.author.username%></h5>

          <!-- <strong>Rating:</strong> -->
          <p class="mb-2 starability-result" data-rating="<%=review.rating%>"> 
            <!-- <review.rating %>⭐ -->
          </p>

          <p class="card-text">
            <%= review.Comment %>
          </p>

          <p class="text-muted small">
            <%= review.createdAt ? review.createdAt.toDateString() : "" %>
          </p>

          <!-- DELETE BUTTON -->
          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-3">
            <button class="btn btn-sm btn-outline-danger btn-light">
              Delete Review
            </button>
          </form>

        </div>
      </div>
    </div>

    <% } %>
  </div>
</div>
<hr>

<h3 class="text-center">Location</h3>

<div id="map" data-coordinates='<%= JSON.stringify(listing.geometry.coordinates) %>' data-title="<%= listing.title %>"></div>

<style>
#map{
height:500px;
width:80%;
margin:20px auto;
border-radius:10px;
box-shadow:0 4px 15px rgba(0,0,0,0.2);
}
</style>

<script src="/js/map.js"></script>